# ── Required ───────────────────────────────────────────────────────────────────
# Full URL of the hosted backend (no trailing slash).
# Leave empty for local dev — Vite proxy handles /api/* automatically.
# Example: https://my-notes-server.vercel.app
VITE_API_URL=

# ── Google OAuth (optional) ────────────────────────────────────────────────────
# Same OAuth 2.0 Web client ID as GOOGLE_CLIENT_ID in the server .env
VITE_GOOGLE_CLIENT_ID=
