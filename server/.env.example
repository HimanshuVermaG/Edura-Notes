# ── Required ───────────────────────────────────────────────────────────────────
# MongoDB connection string (MongoDB Atlas for cloud hosting)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/notes-app?retryWrites=true&w=majority

# JWT secret — use a long random string in production
JWT_SECRET=change-this-to-a-long-random-secret

# Server port (hosting platforms set this automatically; keep for local dev)
PORT=5001

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Example: https://my-notes-app.vercel.app,https://my-notes-app.com
# Leave empty to allow any origin (local dev only — do NOT leave empty in production).
CLIENT_ORIGIN=https://your-client-url.vercel.app

# ── Google OAuth (optional) ────────────────────────────────────────────────────
# OAuth 2.0 Web client ID from Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=

# ── Cloudinary (required for file uploads) ────────────────────────────────────
# Get these from https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Admin account ─────────────────────────────────────────────────────────────
# Email used when running: npm run seed:admin
ADMIN_EMAIL=admin@example.com
